       fhir:reference [ fhir:v "CommunicationRequest/11" ]
     ]
  ] [
     fhir:id [ fhir:v "SDMContinueScreeningLifeExp" ] ;
     fhir:title [ fhir:v "Recommendation: Discuss decision to continue screening" ] ;
     fhir:description [ fhir:v "ACS advises that individuals should continue colorectal cancer screening as long as their overall health is good and they have a life expectancy of 10 years or more. Decision to continue screening in cases of limited life expectancy should be based on shared decision-making." ] ;
