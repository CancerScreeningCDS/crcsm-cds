     fhir:title [ fhir:v "Recommendation: Selectively offer screening" ] ;
     fhir:description [ fhir:v "The USPSTF recommends that clinicians selectively offer screening for colorectal cancer in adults aged 76 to 85 years." ] ;
     fhir:documentation ( [
       fhir:type [ fhir:v "citation" ] ;
       fhir:label [ fhir:v "USPSTF" ] ;
       fhir:display [ fhir:v "Screening for Colorectal Cancer: US Preventive Services Task Force Recommendation Statement" ] ;
